# ============================================================
# Hermes Agent — Environment Variables (copy to ~/.hermes/.env)
# ============================================================
# This file is for reference only. The agent runs on your
# LOCAL machine, not on the production server.
# Copy these values to ~/.hermes/.env on your local machine.
#
# Get your API keys at:
#   MiniMax:  https://www.minimax.io
#   OpenRouter: https://openrouter.ai/keys
# ============================================================

# ── MiniMax (primary LLM) ──────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── OpenRouter (fallback LLM + any model) ──────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Container image for terminal backend ───────────────────
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20

# ── Terminal defaults ──────────────────────────────────────
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
