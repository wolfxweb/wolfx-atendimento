# ============================================================
# wolfx-atendimento — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://postgres:password@postgres_postgres:5432/atendimento_db

# SQLite (development only — leave DATABASE_URL above for production)
# DATABASE_URL=sqlite:///./dev.db

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ── Debug ──────────────────────────────────────────────────
DEBUG=false

# ── CORS (comma-separated list of allowed origins) ──────────
CORS_ORIGINS=https://atendimento.wolfx.com.br,http://localhost:3000

# ── Telegram Bot (AI + notifications) ────────────────────
# Get token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI / Embeddings (MiniMax) ──────────────────────────────
# Get key at: https://www.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── AI Fallback (OpenRouter) ────────────────────────────────
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── AI Module (dry_run mode — no auto-approval) ───────────
# Set to "false" to enable real AI auto-approval workflow
AI_DRY_RUN=true
