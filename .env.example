# ============================================================
# wolfx-atendimento — Environment Variables
# Copy to .env and fill in your values
#
# NOTE: The AI agent (Hermes) runs on your LOCAL machine, not
# on the production server. For agent config, see:
#   hermes.env.example → copy values to ~/.hermes/.env on your local machine
# ============================================================

# ── Database ────────────────────────────────────────────────
# PostgreSQL (production — also update docker-compose.yml ports)
DATABASE_URL=postgresql://postgres:postgres@postgres_postgres:5432/atendimento_db

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ── Debug ──────────────────────────────────────────────────
DEBUG=false

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=https://atendimento.wolfx.com.br,http://localhost:3000

# ── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI / Embeddings (MiniMax) ──────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── AI Fallback (OpenRouter — optional) ────────────────────
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── AI Module ───────────────────────────────────────────────
AI_DRY_RUN=true
